# Silicon2 monorepo — copy to `.env` and adjust paths.
# Orchestrator docs: apps/orchestrator/README.md

SPECS_DIR=/path/to/specs
PHP_PROJECT_ROOT=/path/to/php-project
MCP_SERVER_PATH=/path/to/php-analyzer-mcp
SCREENSHOTS_DIR=./screenshots

# Optional: override auto-detected monorepo root
# PROJECT_ROOT=/path/to/silicon2-migration

PW_BASE_URL=https://dev.stylekorean.com
PW_ADMIN_ID=
PW_ADMIN_PW=

AWS_REGION=us-east-1

# Pipeline concurrency (default 1 until worktree isolation — see phase6-spec 6I)
MAX_PARALLEL_PAGES=1
MAX_PARALLEL_GENERATION=2
MAX_RETRY_ATTEMPTS=3

# Visual diff (Step 4)
VISUAL_SSIM_THRESHOLD=0.85
VISUAL_DIFF_THRESHOLD_PCT=15.0
STRICT_VISUAL_GATE=true
FRONTEND_DEV_PORT=3100
FRONTEND_DEV_STARTUP_TIMEOUT_S=30
STRICT_JAVA_TEST=true

# CLI / MCP paths (defaults: claude, python3)
# CLAUDE_PATH=claude
# MCP_PYTHON_PATH=python3

PROJECT_BUDGET=20000
# ENFORCE_PROJECT_BUDGET=false

# Per-page git worktree isolation (enables safe MAX_PARALLEL_PAGES > 1)
USE_WORKTREE=false

DATABASE_URL=sqlite:///./data/orchestrator.db
ORCH_LOG_LEVEL=INFO
